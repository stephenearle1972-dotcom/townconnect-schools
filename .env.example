# TownConnect Schools — environment variable template.
# Copy to .env (which is git-ignored) and fill in real values.
# NEVER commit .env or any file with real keys.
#
# All bot-related vars live in Netlify, not in the local .env. This template
# is a reference for what's needed once the WhatsApp bot work begins (Thursday).

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Gemini (NEW Google Cloud project — must NOT be the shared TownConnect one)
GEMINI_API_KEY=
GEMINI_PROJECT_ID=

# School data
SCHOOL_CSV_URL=
SCHOOL_NAME=Highveld Academy
SCHOOL_BOT_NUMBER=+27XXXXXXXXX

# Site
SITE_URL=https://schools.townconnect.co.za

# Broadcast demo
BROADCAST_SECRET=
BROADCAST_TEST_NUMBERS=
